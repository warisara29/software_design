# Copy this file to .env (which is git-ignored) and fill in real values.
# DO NOT commit .env — it contains secrets.

# === Confluent Cloud Kafka ===
# Either naming convention works (KAFKA_BROKERS / KAFKA_USERNAME pattern preferred):
KAFKA_BROKERS=pkc-619z3.us-east1.gcp.confluent.cloud:9092
KAFKA_SSL=true
KAFKA_USERNAME=YOUR_API_KEY
KAFKA_PASSWORD=YOUR_API_SECRET

# Legacy alternative names also accepted:
# KAFKA_BOOTSTRAP_SERVERS=pkc-619z3.us-east1.gcp.confluent.cloud:9092
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_API_KEY=YOUR_API_KEY
# KAFKA_API_SECRET=YOUR_API_SECRET

# === Supabase Postgres (Connection Pooler — port 6543) ===
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_SSL=true
